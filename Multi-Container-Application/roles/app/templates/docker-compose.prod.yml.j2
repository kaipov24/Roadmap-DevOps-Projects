services:
  api:
    image: "{{ api_image }}"
    container_name: todo-api
    restart: unless-stopped
    ports:
      - "{{ api_port }}:{{ container_port }}"
    environment:
      PORT: "{{ container_port }}"
      MONGODB_URI: "{{ mongodb_uri }}"
    depends_on:
      - mongodb

  mongodb:
    image: mongo:7
    container_name: todo-api-mongodb
    restart: unless-stopped
    volumes:
      - mongodb_data:/data/db

volumes:
  mongodb_data:
